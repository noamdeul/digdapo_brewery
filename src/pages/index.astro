---
import BaseLayout from "../layouts/BaseLayout.astro";
import BeerCard from "../components/BeerCard.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";

const allBeers = await getCollection("beers");
const featuredBeers = allBeers.filter((b) => b.data.featured);
const brewingNow = allBeers.filter((b) => b.data.status === "brewing");
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <img
        src={`${base}images/brand/logo.png`}
        alt="Digdapo Beer logo"
        class="hero__logo"
      />
      <div class="hero__text">
        <h1>Digdapo <span class="hero__accent">Brewery</span></h1>
        <p class="hero__tagline">
          Craft beer brewed with passion, curiosity, and a giraffe's eye view
          — since 2022.
        </p>
        <a href={`${base}beers/`} class="hero__cta">Explore Our Beers &rarr;</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section about">
    <div class="container about__inner">
      <h2>Our Story</h2>
      <p>
        Digdapo started in a small home kitchen with a simple idea: brew the
        kind of beer we wanted to drink. Each batch is an experiment — from
        hop-forward IPAs to malty stouts, we chase flavours that surprise and
        satisfy.
      </p>
      <p>
        The name? Part inside joke, part manifesto. The giraffe stands tall,
        sees far, and never settles for the ordinary. Neither do we.
      </p>
    </div>
  </section>

  <!-- Currently Brewing -->
  {brewingNow.length > 0 && (
    <section class="section brewing">
      <div class="container">
        <div class="brewing__header">
          <span class="brewing__icon">&#9881;</span>
          <h2>Currently Brewing</h2>
        </div>
        <p class="brewing__subtitle">What's in the fermenter right now.</p>
        <div class="brewing__list">
          {brewingNow.map((beer) => (
            <a href={`${base}beers/${beer.data.slug}/`} class="brewing__card">
              <div class="brewing__card-left">
                <h3>{beer.data.title}</h3>
                <span class="brewing__style">{beer.data.style}</span>
              </div>
              <div class="brewing__card-right">
                <p class="brewing__desc">{beer.data.shortDescription}</p>
                <div class="brewing__meta">
                  <span class="badge badge--brewing">brewing</span>
                  <span class="brewing__abv">{beer.data.abv != null ? `Target ${beer.data.abv}% ABV` : 'ABV TBD'}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured beers -->
  {featuredBeers.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>Featured Brews</h2>
        <div class="beer-grid" style="margin-top:1.5rem;">
          {featuredBeers.map((beer) => (
            <BeerCard
              title={beer.data.title}
              slug={beer.data.slug}
              style={beer.data.style}
              abv={beer.data.abv}
              status={beer.data.status}
              shortDescription={beer.data.shortDescription}
              heroImage={beer.data.heroImage}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background:
      linear-gradient(to bottom, var(--color-bg-alt), var(--color-bg));
    padding-block: 4rem 5rem;
  }

  .hero__inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__logo {
    width: min(320px, 80vw);
    border-radius: var(--radius);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .hero__text {
    max-width: 480px;
    text-align: left;
  }

  .hero__accent {
    color: var(--color-amber);
  }

  .hero__tagline {
    margin-top: 1rem;
    font-size: 1.15rem;
    color: var(--color-cream-dim);
    line-height: 1.6;
  }

  .hero__cta {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-rust);
    color: var(--color-cream);
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }

  .hero__cta:hover {
    background: var(--color-coral);
    color: var(--color-cream);
  }

  /* About */
  .about__inner {
    max-width: 700px;
  }

  .about__inner h2 {
    margin-bottom: 1rem;
  }

  .about__inner p {
    color: var(--color-cream-dim);
    margin-bottom: 1rem;
  }

  /* Currently Brewing */
  .brewing__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brewing__icon {
    font-size: 1.6rem;
    animation: spin 4s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .brewing__subtitle {
    color: var(--color-text-muted);
    margin-top: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .brewing__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .brewing__card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border-left: 4px solid var(--color-coral);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .brewing__card:hover {
    transform: translateX(4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .brewing__card-left {
    flex-shrink: 0;
    min-width: 140px;
  }

  .brewing__card-left h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--color-cream);
  }

  .brewing__style {
    font-size: 0.85rem;
    color: var(--color-amber);
    font-weight: 500;
  }

  .brewing__desc {
    font-size: 0.9rem;
    color: var(--color-cream-dim);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .brewing__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brewing__abv {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .brewing__card {
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  @media (max-width: 768px) {
    .hero__inner {
      flex-direction: column;
      text-align: center;
    }

    .hero__text {
      text-align: center;
    }
  }
</style>
