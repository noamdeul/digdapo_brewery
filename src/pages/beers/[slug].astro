---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import { getCollection } from "astro:content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const beers = await getCollection("beers");
  return beers.map((beer) => ({
    params: { slug: beer.data.slug },
    props: { beer },
  }));
}

const { beer } = Astro.props;
const { Content } = await render(beer);
const base = import.meta.env.BASE_URL;
const d = beer.data;

const statusClass =
  d.status === "on tap" ? "badge--gold" :
  d.status === "conditioning" ? "" :
  "badge--muted";
---

<BaseLayout title={d.title} description={d.shortDescription}>
  <article class="beer-detail">
    <!-- Hero image -->
    <div class="beer-detail__hero">
      {d.heroImage ? (
        <img src={`${base}${d.heroImage}`} alt={d.title} />
      ) : (
        <div class="beer-detail__hero-placeholder">
          <span>🍺</span>
        </div>
      )}
    </div>

    <div class="container beer-detail__content">
      <!-- Header row -->
      <div class="beer-detail__header">
        {d.logoImage && (
          <img
            src={`${base}${d.logoImage}`}
            alt={`${d.title} label`}
            class="beer-detail__logo"
          />
        )}
        <div>
          <h1>{d.title}</h1>
          <p class="beer-detail__style">{d.style}</p>
          <span class={`badge ${statusClass}`}>{d.status}</span>
        </div>
      </div>

      <!-- Stats -->
      <div class="beer-detail__stats">
        <div class="stat">
          <span class="stat__value">{d.abv}%</span>
          <span class="stat__label">ABV</span>
        </div>
        {d.ibu && (
          <div class="stat">
            <span class="stat__value">{d.ibu}</span>
            <span class="stat__label">IBU</span>
          </div>
        )}
        <div class="stat">
          <span class="stat__value">{d.batchDate}</span>
          <span class="stat__label">Batch Date</span>
        </div>
      </div>

      <!-- Description & tasting notes -->
      <div class="beer-detail__body">
        <p class="beer-detail__desc">{d.shortDescription}</p>

        {d.tastingNotes && (
          <div class="beer-detail__notes">
            <h3>Tasting Notes</h3>
            <p>{d.tastingNotes}</p>
          </div>
        )}

        {d.ingredients && d.ingredients.length > 0 && (
          <div class="beer-detail__ingredients">
            <h3>Ingredients</h3>
            <ul>
              {d.ingredients.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}

        <!-- Markdown body content -->
        <div class="beer-detail__prose">
          <Content />
        </div>
      </div>

      <!-- Gallery -->
      {d.gallery && d.gallery.length > 0 && (
        <div class="beer-detail__gallery">
          <h3>Gallery</h3>
          <div class="gallery-grid">
            {d.gallery.map((img) => (
              <img src={`${base}${img}`} alt={`${d.title} photo`} />
            ))}
          </div>
        </div>
      )}

      <a href={`${base}beers/`} class="beer-detail__back">&larr; All Beers</a>
    </div>
  </article>
</BaseLayout>

<style>
  .beer-detail__hero {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .beer-detail__hero img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  .beer-detail__hero-placeholder {
    height: 260px;
    display: grid;
    place-items: center;
    font-size: 4rem;
    opacity: 0.2;
  }

  .beer-detail__content {
    padding-block: 2.5rem 4rem;
  }

  .beer-detail__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .beer-detail__logo {
    width: 100px;
    height: 100px;
    border-radius: var(--radius);
    object-fit: cover;
    border: 2px solid var(--color-surface);
  }

  .beer-detail__style {
    color: var(--color-amber);
    font-weight: 500;
    margin: 0.25rem 0 0.5rem;
  }

  /* Stats row */
  .beer-detail__stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border-radius: var(--radius);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .stat__value {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-gold);
  }

  .stat__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  /* Body */
  .beer-detail__body {
    max-width: 720px;
  }

  .beer-detail__desc {
    font-size: 1.1rem;
    color: var(--color-cream-dim);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .beer-detail__notes,
  .beer-detail__ingredients {
    margin-bottom: 1.5rem;
  }

  .beer-detail__notes h3,
  .beer-detail__ingredients h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .beer-detail__notes p {
    color: var(--color-cream-dim);
  }

  .beer-detail__ingredients ul {
    list-style: disc;
    padding-left: 1.25rem;
    color: var(--color-cream-dim);
  }

  .beer-detail__ingredients li {
    margin-bottom: 0.25rem;
  }

  .beer-detail__prose {
    color: var(--color-cream-dim);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .beer-detail__prose :global(h2),
  .beer-detail__prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .beer-detail__prose :global(p) {
    margin-bottom: 1rem;
  }

  /* Gallery */
  .beer-detail__gallery {
    margin-top: 2.5rem;
  }

  .beer-detail__gallery h3 {
    margin-bottom: 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .gallery-grid img {
    border-radius: var(--radius-sm);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .beer-detail__back {
    display: inline-block;
    margin-top: 2.5rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .beer-detail__stats {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .beer-detail__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
