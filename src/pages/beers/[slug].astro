---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import { getCollection } from "astro:content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const beers = await getCollection("beers");
  return beers.map((beer) => ({
    params: { slug: beer.data.slug },
    props: { beer },
  }));
}

const { beer } = Astro.props;
const { Content } = await render(beer);
const base = import.meta.env.BASE_URL;
const d = beer.data;

const statusClass =
  d.status === "brewing" ? "badge--brewing" :
  d.status === "on tap" ? "badge--gold" :
  d.status === "conditioning" ? "" :
  "badge--muted";
---

<BaseLayout title={d.title} description={d.shortDescription}>
  <article class="beer-detail">
    <!-- Hero image -->
    <div class="beer-detail__hero">
      <img
        src={d.heroImage ? `${base}${d.heroImage}` : `${base}images/brand/placeholder.svg`}
        alt={d.title}
        data-fallback={`${base}images/brand/placeholder.svg`}
      />
    </div>

    <div class="container beer-detail__content">
      <!-- Header row -->
      <div class="beer-detail__header">
        {d.logoImage && (
          <img
            src={`${base}${d.logoImage}`}
            alt={`${d.title} label — click to enlarge`}
            class="beer-detail__logo"
            data-lightbox
            data-fallback={`${base}images/brand/placeholder.svg`}
          />
        )}
        <div>
          <h1>{d.title}</h1>
          <p class="beer-detail__style">{d.style}</p>
          <span class={`badge ${statusClass}`}>{d.status}</span>
        </div>
      </div>

      <!-- Stats -->
      <div class="beer-detail__stats">
        <div class="stat">
          <span class={`stat__value${d.abv == null ? ' stat__value--tbd' : ''}`}>{d.abv != null ? `${d.abv}%` : 'TBD'}</span>
          <span class="stat__label">ABV</span>
        </div>
        {d.ibu != null && (
          <div class="stat">
            <span class="stat__value">{d.ibu}</span>
            <span class="stat__label">IBU</span>
          </div>
        )}
        <div class="stat">
          <span class="stat__value">{d.batchDate}</span>
          <span class="stat__label">Batch Date</span>
        </div>
      </div>

      <!-- Description & tasting notes -->
      <div class="beer-detail__body">
        <p class="beer-detail__desc">{d.shortDescription}</p>

        {d.tastingNotes && (
          <div class="beer-detail__notes">
            <h3>Tasting Notes</h3>
            <p>{d.tastingNotes}</p>
          </div>
        )}

        {d.ingredients && d.ingredients.length > 0 && (
          <div class="beer-detail__ingredients">
            <h3>Ingredients</h3>
            <ul>
              {d.ingredients.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}

        <!-- Markdown body content -->
        <div class="beer-detail__prose">
          <Content />
        </div>
      </div>

      <!-- Gallery -->
      {d.gallery && d.gallery.length > 0 && (
        <div class="beer-detail__gallery">
          <h3>Gallery</h3>
          <div class="gallery-grid">
            {d.gallery.map((img) => (
              <img src={`${base}${img}`} alt={`${d.title} photo`} data-fallback={`${base}images/brand/placeholder.svg`} />
            ))}
          </div>
        </div>
      )}

      <a href={`${base}beers/`} class="beer-detail__back">&larr; All Beers</a>
    </div>
  </article>

  <!-- Lightbox modal -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" aria-label="Close">&times;</button>
    <img class="lightbox__img" id="lightbox-img" alt="" />
  </div>
</BaseLayout>

<style>
  .beer-detail__hero {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .beer-detail__hero img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  .beer-detail__content {
    padding-block: 2.5rem 4rem;
  }

  .beer-detail__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .beer-detail__logo {
    width: 100px;
    height: 100px;
    border-radius: var(--radius);
    object-fit: cover;
    border: 2px solid var(--color-surface);
    cursor: zoom-in;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .beer-detail__logo:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .beer-detail__style {
    color: var(--color-amber);
    font-weight: 500;
    margin: 0.25rem 0 0.5rem;
  }

  /* Stats row */
  .beer-detail__stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border-radius: var(--radius);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .stat__value {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-gold);
  }

  .stat__value--tbd {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .stat__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  /* Body */
  .beer-detail__body {
    max-width: 720px;
  }

  .beer-detail__desc {
    font-size: 1.1rem;
    color: var(--color-cream-dim);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .beer-detail__notes,
  .beer-detail__ingredients {
    margin-bottom: 1.5rem;
  }

  .beer-detail__notes h3,
  .beer-detail__ingredients h3 {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .beer-detail__notes p {
    color: var(--color-cream-dim);
  }

  .beer-detail__ingredients ul {
    list-style: disc;
    padding-left: 1.25rem;
    color: var(--color-cream-dim);
  }

  .beer-detail__ingredients li {
    margin-bottom: 0.25rem;
  }

  .beer-detail__prose {
    color: var(--color-cream-dim);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .beer-detail__prose :global(h2),
  .beer-detail__prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .beer-detail__prose :global(p) {
    margin-bottom: 1rem;
  }

  /* Gallery */
  .beer-detail__gallery {
    margin-top: 2.5rem;
  }

  .beer-detail__gallery h3 {
    margin-bottom: 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .gallery-grid img {
    border-radius: var(--radius-sm);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .beer-detail__back {
    display: inline-block;
    margin-top: 2.5rem;
    font-weight: 600;
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    place-items: center;
    cursor: zoom-out;
  }

  .lightbox.open {
    display: grid;
  }

  .lightbox__img {
    max-width: min(90vw, 720px);
    max-height: 85vh;
    border-radius: var(--radius);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    animation: lightbox-in 0.25s ease-out;
  }

  @keyframes lightbox-in {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lightbox__close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: var(--color-cream);
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .lightbox__close:hover {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .beer-detail__stats {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .beer-detail__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox?.classList.add('open');
    lightbox?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.remove('open');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLImageElement>('[data-lightbox]').forEach((img) => {
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target !== lightboxImg) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
